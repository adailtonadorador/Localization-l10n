VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Maps Geocoding API (server-side only, sem prefixo VITE_)
# Ative a API em: https://console.cloud.google.com > APIs & Services > Geocoding API
# Restrinja a chave para: API restrictions > Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Web Push Notifications (VAPID Keys)
# Gere as chaves em: https://vapidkeys.com/ ou use: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# Para a Edge Function (configurar no Supabase Dashboard > Edge Functions > Secrets)
# VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_EMAIL=mailto:contato@seudominio.com
